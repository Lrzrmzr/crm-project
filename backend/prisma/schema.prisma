generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  admin
  agent
}

enum LeadStatus {
  new
  contacted
  qualified
  converted
  lost
}

enum DealStage {
  prospecting
  proposal
  negotiation
  won
  lost
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String   @db.VarChar(255)
  email        String   @unique @db.VarChar(255)
  passwordHash String   @db.VarChar(255)
  role         UserRole @default(agent)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now()) @db.Timestamptz
  updatedAt    DateTime @updatedAt @db.Timestamptz

  refreshTokens   RefreshToken[]
  companiesCreated Company[]
  contactsAssigned Contact[] @relation("ContactAssignedTo")
  contactsCreated  Contact[] @relation("ContactCreatedBy")
  leadsAssigned    Lead[]    @relation("LeadAssignedTo")
  leadsCreated     Lead[]    @relation("LeadCreatedBy")
  dealsAssigned    Deal[]    @relation("DealAssignedTo")
  dealsCreated     Deal[]    @relation("DealCreatedBy")

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @db.VarChar(255)
  expiresAt DateTime  @db.Timestamptz
  revokedAt DateTime? @db.Timestamptz
  createdAt DateTime  @default(now()) @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Company {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @db.VarChar(255)
  industry  String?  @db.VarChar(100)
  website   String?  @db.VarChar(255)
  phone     String?  @db.VarChar(50)
  address   String?
  createdBy String   @db.Uuid
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  creator  User      @relation(fields: [createdBy], references: [id])
  contacts Contact[]

  @@map("companies")
}

model Contact {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firstName  String   @db.VarChar(100)
  lastName   String   @db.VarChar(100)
  email      String?  @db.VarChar(255)
  phone      String?  @db.VarChar(50)
  companyId  String?  @db.Uuid
  assignedTo String?  @db.Uuid
  notes      String?
  createdBy  String   @db.Uuid
  createdAt  DateTime @default(now()) @db.Timestamptz
  updatedAt  DateTime @updatedAt @db.Timestamptz

  company      Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  assignedUser User?    @relation("ContactAssignedTo", fields: [assignedTo], references: [id])
  creator      User     @relation("ContactCreatedBy", fields: [createdBy], references: [id])
  leads        Lead[]
  deals        Deal[]

  @@map("contacts")
}

model Lead {
  id             String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title          String     @db.VarChar(255)
  contactId      String     @db.Uuid
  assignedTo     String?    @db.Uuid
  status         LeadStatus @default(new)
  source         String?    @db.VarChar(100)
  estimatedValue Decimal?   @db.Decimal(12, 2)
  notes          String?
  createdBy      String     @db.Uuid
  createdAt      DateTime   @default(now()) @db.Timestamptz
  updatedAt      DateTime   @updatedAt @db.Timestamptz

  contact      Contact @relation(fields: [contactId], references: [id])
  assignedUser User?   @relation("LeadAssignedTo", fields: [assignedTo], references: [id])
  creator      User    @relation("LeadCreatedBy", fields: [createdBy], references: [id])
  deals        Deal[]

  @@map("leads")
}

model Deal {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title         String    @db.VarChar(255)
  leadId        String?   @db.Uuid
  contactId     String    @db.Uuid
  assignedTo    String?   @db.Uuid
  stage         DealStage @default(prospecting)
  value         Decimal?  @db.Decimal(12, 2)
  expectedClose DateTime? @db.Date
  closedAt      DateTime? @db.Timestamptz
  notes         String?
  createdBy     String    @db.Uuid
  createdAt     DateTime  @default(now()) @db.Timestamptz
  updatedAt     DateTime  @updatedAt @db.Timestamptz

  lead         Lead?   @relation(fields: [leadId], references: [id])
  contact      Contact @relation(fields: [contactId], references: [id])
  assignedUser User?   @relation("DealAssignedTo", fields: [assignedTo], references: [id])
  creator      User    @relation("DealCreatedBy", fields: [createdBy], references: [id])

  @@map("deals")
}